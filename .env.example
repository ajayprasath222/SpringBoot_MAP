# Railway / production — Gmail SMTP

JWT_SECRET=change-me-production-jwt-secret-min-32-chars

# Gmail SMTP (App Password — not your normal Gmail password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-16-char-gmail-app-password
MAIL_FROM=your@gmail.com

# If port 465 fails, try:
# MAIL_PORT=587
# MAIL_SSL_ENABLE=false
# MAIL_STARTTLS_ENABLE=true
