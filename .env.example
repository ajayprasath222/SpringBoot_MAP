# Copy to .env and fill in values before: docker compose up -d --build

# --- Database ---
DB_PASSWORD=change-me-strong-db-password

# --- JWT (min 32 characters) ---
JWT_SECRET=change-me-production-jwt-secret-min-32-chars

# --- Gmail SMTP ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your@gmail.com

# Optional
# JPA_DDL_AUTO=update
# JWT_TTL_SECONDS=86400
