# Copy to: application-local-secrets.properties (gitignored)
# Restart the app after editing.

# =============================================================================
# OPTION A — Brevo SMTP (recommended when Gmail App Passwords are unavailable)
# Free: https://www.brevo.com → Sign up → SMTP & API → Generate SMTP key
# Verify sender email (Settings → Senders) — use golane360@gmail.com
# =============================================================================
#app.mail.embedded=false
#spring.mail.host=smtp-relay.brevo.com
#spring.mail.port=587
#spring.mail.username=your-brevo-login-email@example.com
#spring.mail.password=your-brevo-smtp-key
#spring.mail.properties.mail.smtp.auth=true
#spring.mail.properties.mail.smtp.starttls.enable=true
#spring.mail.properties.mail.smtp.starttls.required=true
#app.mail.from=golane360@gmail.com

# =============================================================================
# OPTION B — Gmail (only if App Passwords page works for your account)
# https://myaccount.google.com/apppasswords
# Not available if: work/school account, Advanced Protection, or 2FA = security keys only
# =============================================================================
#app.mail.embedded=false
#spring.mail.host=smtp.gmail.com
#spring.mail.port=587
#spring.mail.username=golane360@gmail.com
#spring.mail.password=your-16-char-gmail-app-password
#spring.mail.properties.mail.smtp.auth=true
#spring.mail.properties.mail.smtp.starttls.enable=true
#spring.mail.properties.mail.smtp.starttls.required=true
#spring.mail.properties.mail.smtp.ssl.trust=smtp.gmail.com
#app.mail.from=golane360@gmail.com
